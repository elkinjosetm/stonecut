#!/usr/bin/env bash
# Pre-commit hook: run eslint and prettier checks.
# Install: git config core.hooksPath .githooks

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

echo "Running eslint..."
cd "$ROOT" && npx eslint src/ tests/

echo "Running prettier --check..."
cd "$ROOT" && npx prettier --check .
